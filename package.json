{
  "allowScripts": {
    "@swc/core@1.15.41": true,
    "unrs-resolver": false
  },
  "author": "KeeeX SAS",
  "bugs": {
    "url": "https://forge.keeex.net/KeeeX/lib_node_pm2-status/issues"
  },
  "cleanPublish": {
    "behavior": {
      "cleanPrepack": {
        "README.md": {
          "remove": [
            "https://devtools.keeex.me",
            "https://devtools.keeex.net",
            "https://sast.keeex.net",
            "https://forge.keeex.net",
            "https://cicd.keeex.net",
            "https://docs.keeex.me"
          ],
          "type": "text"
        },
        "package.json": {
          "add": {
            "homepage": "https://keeex.me/oss"
          },
          "remove": [
            "repository"
          ],
          "type": "json"
        },
        "sonar-project.properties": "remove"
      },
      "cleanPublish": {
        "package.json": {
          "package": true,
          "remove": [
            "repository"
          ],
          "type": "json"
        }
      },
      "cleanSource": {
        "README.md": {
          "remove": [
            "https://devtools.keeex.me",
            "https://devtools.keeex.net",
            "https://sast.keeex.net",
            "https://forge.keeex.net",
            "https://cicd.keeex.net",
            "https://docs.keeex.me"
          ],
          "type": "text"
        },
        "package.json": {
          "add": {
            "homepage": "https://keeex.me/oss",
            "scripts": {
              "build": "tslib build",
              "check": "tslib check",
              "clean": "tslib clean",
              "prepack": "npm run clean && npm run build",
              "test": "tslib test"
            }
          },
          "remove": [
            "repository",
            "cleanPublish"
          ],
          "type": "json"
        },
        "sonar-project.properties": "remove"
      }
    }
  },
  "contributors": [
    {
      "email": "gabriel@keeex.net",
      "name": "Gabriel Paul \"Cley Faye\" Risterucci"
    }
  ],
  "description": "Check some PM2 attributes from environment variables",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@keeex/clean-publish": "^1.4.2",
    "@keeex/eslint-config": "^2.6.3",
    "@keeex/tslib": "^2.15.1",
    "@swc/core": "^1.15.41",
    "@types/node": "^24.13.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.6.0",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "exports": {
    ".": "./lib/pm2.js"
  },
  "files": [
    "lib"
  ],
  "homepage": "https://forge.keeex.net/KeeeX/lib_node_pm2-status",
  "keywords": [
    "pm2",
    "log",
    "environment",
    "variable"
  ],
  "license": "MIT",
  "main": "./lib/pm2.js",
  "name": "@keeex/pm2-status",
  "repository": {
    "type": "git",
    "url": "ssh://git@forge.keeex.net:KeeeX/lib_node_pm2-status.git"
  },
  "scripts": {
    "check": "tslib check",
    "clean": "tslib clean",
    "postpack": "clean-publish restore",
    "prepack": "tslib build && clean-publish cleanPublish",
    "prepublishOnly": "publish_check"
  },
  "tslib": {
    "exports": {
      "enabled": true,
      "private": [
        "pm2.ts"
      ]
    },
    "testPattern": "none"
  },
  "type": "module",
  "version": "1.0.1"
}
